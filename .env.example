# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ecommerce_user:ecommerce_pass@localhost:5432/ecommerce_dev

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_hex_secret
JWT_REFRESH_SECRET=replace_with_different_64_char_hex_secret

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ── Paystack ────────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# ── AWS / S3 ──────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_BUCKET_PRODUCTS=your-products-bucket-name
S3_BUCKET_DOCUMENTS=your-documents-bucket-name
CLOUDFRONT_DOMAIN=https://xxxxxxxxxxxxxx.cloudfront.net

# ── Vendor ────────────────────────────────────────────────────────────────────
# Amount in smallest currency unit (5000 = $50.00 USD)
VENDOR_ONBOARDING_FEE=5000
